APP_ENV=dev
PORT=3000
JWT_SECRET=replace-me
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:5173

# sqlite is used when APP_ENV is local/dev
SQLITE_FILE=./data/gastroman.sqlite

# mariadb is used when APP_ENV is staging/prod
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=
MARIADB_DATABASE=gastroman
MARIADB_CONNECTION_LIMIT=5
